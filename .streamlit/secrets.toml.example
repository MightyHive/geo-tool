# Copy to secrets.toml and fill in real values. Do not commit secrets.toml.
#
# Environments (development / staging / production)
# - Set APP_ENV or GEO_ENV in the shell or in repo-root .env (see geo_app_env.py).
# - Per-host variables (WEB_PUBLIC_ORIGIN, GA4_*, etc.) belong in env/.env.<name>
#   (copy from env/.env.*.example).
# - Use separate Google OAuth clients if redirect URIs differ per environment.
#
# Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client ID (Web application).
# Add every redirect you use, for example (prod dev via ngrok):
#   https://YOUR-SUBDOMAIN.ngrok-free.dev/api/auth/callback # Web UI sign-in (FastAPI)
#   https://YOUR-SUBDOMAIN.ngrok-free.dev/api/ga4/callback  # Web UI GA4 OAuth
# Local-only examples:
#   http://localhost:5173/api/auth/callback   # Web UI sign-in (Vite dev proxy)
#   http://localhost:5173/api/ga4/callback    # Web UI GA4 OAuth (Vite dev proxy)
#   http://127.0.0.1:5173/api/auth/callback   # same app if you open 127.0.0.1:5173
# Authorized JavaScript origins (same hosts, no path): http://localhost:5173, http://127.0.0.1:5173
#
# TypeScript web UI: set WEB_PUBLIC_ORIGIN in env/.env.development (default http://localhost:5173).
# The API uses redirect URI {WEB_PUBLIC_ORIGIN}/api/auth/callback — must be listed in Google Cloud.
#
# Identity-Aware Proxy (staging/production behind GCP load balancer + IAP):
# [iap]
# enabled = true
# audience = "IAP_OAUTH_CLIENT_ID.apps.googleusercontent.com"  # IAP → HTTPS resources → Client ID
# enforce = true
# hosted_domain = "yourcompany.com"  # optional — restrict to Workspace domain
#
# cookie_secret: long random string (e.g. `openssl rand -hex 32`).
#
# Troubleshooting — Google sign-in
# - OAuth settings must live under a literal ``[auth]`` header in TOML—not as bare keys at the top of the file.
# - **Invalid TOML** (e.g. unquoted URLs) makes the whole file fail to parse—use ``key = "value"`` for strings.
# - ``[auth]`` needs: ``cookie_secret``, ``client_id``, ``client_secret``, ``server_metadata_url``.
# - Web redirect URI is ``{WEB_PUBLIC_ORIGIN}/api/auth/callback`` (see env/.env.development).

[auth]
cookie_secret = "REPLACE_WITH_RANDOM_SECRET"
client_id = "YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_GOOGLE_OAUTH_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Optional: explicit GA4 OAuth block (otherwise the app reuses [auth] client + GA4 redirect below).
# Enable Google Analytics Admin API + Google Analytics Data API on the GCP project.
# OAuth consent screen: add scopes
#   https://www.googleapis.com/auth/analytics.readonly
#   openid, email, profile (or the userinfo.* URLs) if GA4 reuses the same client as [auth].

# [ga4_oauth]
# client_id = "YOUR_CLIENT.apps.googleusercontent.com"
# client_secret = "YOUR_SECRET"
# redirect_uri = "https://automated-posted-carmaker.ngrok-free.dev/"

# Optional — LLM API keys (top-level OR under [llm] — see competitor_suggest._get_config).
# Competitor search uses Gemini only. Prompt performance live probe uses OpenAI + Gemini.
#
# Top-level (also mirrored to process env by Streamlit):
# GEMINI_API_KEY = "…"
# OPENAI_API_KEY = "sk-…"
#
# Or group in a table (nested keys are NOT auto-exported to os.environ; the app reads them):
# [llm]
# GEMINI_API_KEY = "…"
# OPENAI_API_KEY = "sk-…"
#
# Or use Vertex with ADC instead of a Gemini API key: GEMINI_USE_VERTEX_AI = "1" and GOOGLE_CLOUD_PROJECT = "…"
