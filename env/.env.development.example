# Copy to: env/.env.development (gitignored — do not commit secrets)
# Run: APP_ENV=development streamlit run streamlit_app.py
# Or: ./scripts/run_streamlit_dev.sh

APP_ENV=development

# OAuth / Streamlit must match Google Cloud "Authorized JavaScript origins" + redirect URIs.
# Local dev default is http://localhost:8501 if this line is omitted (see geo_app_env.py).
STREAMLIT_PUBLIC_ORIGIN=http://localhost:8501

# TypeScript web UI (Vite + FastAPI). OAuth callback: {WEB_PUBLIC_ORIGIN}/api/auth/callback
WEB_PUBLIC_ORIGIN=http://localhost:5173

# Optional: test IAP locally (no real JWT) — requires IAP_ENABLED=true in secrets or env
# IAP_ENABLED=true
# IAP_AUDIENCE=YOUR_IAP_OAUTH_CLIENT_ID.apps.googleusercontent.com
# IAP_ENFORCE=false
# IAP_DEV_USER_EMAIL=you@yourcompany.com

# Optional GA4 / crawl defaults (same keys as root .env)
# GA4_PROPERTY_ID=
# GA4_AI_CHANNEL_NAMES=
# GOOGLE_APPLICATION_CREDENTIALS=
