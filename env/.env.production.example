# Copy to: env/.env.production (gitignored)
# Run: APP_ENV=production streamlit run streamlit_app.py
# Or: ./scripts/run_streamlit_prod.sh

APP_ENV=production

# Required: canonical public URL of the deployed app (Streamlit Community Cloud, ECS, etc.)
STREAMLIT_PUBLIC_ORIGIN=https://your-production-host.example.com
WEB_PUBLIC_ORIGIN=https://your-production-host.example.com

# Identity-Aware Proxy — users authenticate at the load balancer; app verifies JWT
IAP_ENABLED=true
IAP_AUDIENCE=YOUR_IAP_OAUTH_CLIENT_ID.apps.googleusercontent.com
IAP_ENFORCE=true
# IAP_HOSTED_DOMAIN=yourcompany.com

# Prefer workload identity or secrets manager in prod; path below is only if you mount a file.
# GOOGLE_APPLICATION_CREDENTIALS=
# GA4_PROPERTY_ID=
