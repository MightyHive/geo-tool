# Copy to: env/.env.staging (gitignored)
# Deploy: ./scripts/deploy_cloud_run_staging.sh

APP_ENV=staging

# Required: public URL of the deployed web app (Cloud Run, load balancer, etc.)
WEB_PUBLIC_ORIGIN=https://your-staging-host.example.com
DEPLOY_PUBLIC_ORIGIN=https://your-staging-host.example.com

# Identity-Aware Proxy (recommended for staging/production)
IAP_ENABLED=true
IAP_ENFORCE=true
# Cloud Run IAP (JWT aud = service path — set this OR rely on auto-detect via K_SERVICE):
# IAP_AUDIENCE=/projects/PROJECT_NUMBER/locations/europe-west1/services/geo-audit-staging
# HTTPS load balancer + IAP (JWT aud = OAuth client ID from IAP console):
# IAP_OAUTH_CLIENT_ID=YOUR_IAP_OAUTH_CLIENT_ID.apps.googleusercontent.com
# Optional explicit region if auto-detect fails:
# CLOUD_RUN_REGION=europe-west1
# IAP_HOSTED_DOMAIN=yourcompany.com

# GA4 wizard OAuth (Cloud Run — or reuse [auth] in secrets.toml locally):
# GA4_OAUTH_CLIENT_ID=
# GA4_OAUTH_CLIENT_SECRET=
# GA4_OAUTH_REDIRECT_URI=https://YOUR-SERVICE.run.app/api/ga4/callback
# Or run: ./scripts/cloud_run_configure_ga4_oauth.sh
#
# GA4_PROPERTY_ID=
# GA4_AI_CHANNEL_NAMES=
# GOOGLE_APPLICATION_CREDENTIALS=
